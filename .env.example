SERVICE_NAME=go-service-template-pro
APP_ENV=local
SERVICE_VERSION=1.0.0
HTTP_PORT=8080
DATABASE_URL=postgres://app:app@localhost:5432/go_service_template_pro?sslmode=disable
AUTH_API_KEYS=client-demo-key-2026
JWT_SECRET=super-secret-for-demo-only
JWT_ISSUER=go-service-template-pro
JWT_AUDIENCE=ops-clients
RATE_LIMIT_RPS=15
RATE_LIMIT_BURST=30
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SEED_DEMO_DATA=true
