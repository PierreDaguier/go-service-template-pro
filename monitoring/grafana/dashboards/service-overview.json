{
  "id": null,
  "uid": "go-service-template-overview",
  "title": "Go Service Template - Reliability Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Requests per second",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(service_http_requests_total[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "5xx error rate",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "sum(rate(service_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(service_http_requests_total[5m])), 1)", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 latency (ms)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(service_http_request_duration_ms_bucket[5m])) by (le))", "refId": "A" }
      ]
    }
  ]
}
